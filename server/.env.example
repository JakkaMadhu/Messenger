# Resend API Key for sending OTP verification emails
RESEND_API_KEY="re_your_resend_api_key_here"

# Server Bind Address
IP_ADDRESS="127.0.0.1"
PORT_NUMBER="45999"

# MongoDB Database Connection Configuration (Either separated or single URI)
# Option A: Separated configurations (handles special character URL-encoding automatically)
MONGODB_USER="username"
MONGODB_PASSWORD="raw_password"
MONGODB_HOST="cluster.mongodb.net"
MONGODB_DB_NAME="db_messenger"
MONGODB_APP_NAME="Messenger"

# Option B: Fallback connection string
# MONGODB_URI="mongodb://username:password@127.0.0.1:27017/db_messenger?authSource=db_messenger"
